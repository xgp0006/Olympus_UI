#!/bin/bash
# AEROSPACE GATE 1: Pre-commit Validation (staged-scope)
# NASA JPL Rule 10: Zero warnings tolerated on what gets committed.
#
# Scope: this hook runs prettier + eslint against ONLY the files staged for
# this commit, via lint-staged. It is intentionally fast (sub-second on a
# typical commit) and does not gate on pre-existing codebase issues outside
# the diff. Full-codebase validation (type check, full lint, tests, NASA JPL
# function-length, console.log/TODO grep, etc.) runs in CI on every push.
#
# This split is the standard layered defense:
#   - pre-commit: fast feedback on the diff (catches issues before they enter)
#   - CI:         comprehensive validation on a clean runner
#   - branch protection: requires CI to be green before merge
#
# Bypass (forbidden): NEVER use `git commit --no-verify`. If this gate fails,
# fix the cause. See CONTRIBUTING.md for the documented exception process.

set -euo pipefail

echo "🚀 AEROSPACE GATE 1: Pre-commit Validation (staged-scope)"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

pnpm exec lint-staged

echo "✅ AEROSPACE GATE 1 PASSED"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
