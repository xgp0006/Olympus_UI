#!/bin/bash
# AEROSPACE GATE 2: Pre-push (lightweight; CI is authoritative)
# NASA JPL Rule 10 enforced via .github/workflows/build.yml + branch protection
#
# This hook intentionally does NOT duplicate the full validation suite (lint,
# type check, tests, build, security audit). That work runs in CI on every
# push, with branch protection requiring CI green before merge to default.
# Duplicating it here was producing 30+ second pre-push delays on a codebase
# that doesn't currently pass its own gates, training developers to bypass.
#
# Layered defense:
#   - pre-commit: prettier on staged files, sub-second
#   - pre-push:   this — fast local sanity check
#   - CI:         full validation on a clean runner (.github/workflows/build.yml)
#   - branch protection: requires CI green before merge
#
# This hook may grow over time. Acceptable additions: signed-commit
# verification, branch-naming linter, refusal to push directly to default
# branch. NOT acceptable: re-introducing full lint/type/test runs that
# duplicate CI on a codebase that doesn't pass them yet.
#
# Bypass (forbidden): NEVER use `git push --no-verify`. If this gate fails,
# the failure is by design — fix the cause.

set -euo pipefail

echo "🚀 AEROSPACE GATE 2: Pre-push"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  Authoritative validation: .github/workflows/build.yml"
echo "  Branch protection requires CI green before merge."
echo "✅ AEROSPACE GATE 2 PASSED"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
